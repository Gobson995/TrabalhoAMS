{
  "name": "dicionario-libras",
  "version": "1.0.0",
  "description": "Dicionário Libras+ — expansão do Dicionário da Língua Brasileira de Sinais (Libras). Aplicação web MVC em TypeScript com PostgreSQL.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx seeds/seed.ts",
    "db:reset": "tsx scripts/migrate.ts --reset && tsx seeds/seed.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,ejs}\" \"tests/**/*.ts\"",
    "diagrams": "bash scripts/render-diagrams.sh",
    "docs:export": "bash scripts/export-docs.sh"
  },
  "keywords": [
    "libras",
    "dicionario",
    "acessibilidade",
    "wcag",
    "lgpd",
    "mvc",
    "typescript"
  ],
  "author": "Vinicius Kruger, Gustavo Bada, Gustavo Hold, Lucas K",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.41.1",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
