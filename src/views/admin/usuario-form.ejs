<%- include('../partials/head', { titulo }) %>
<%- include('../partials/header') %>

<%
  const editando = !!alvo;
  const action = editando ? ('/admin/usuarios/' + alvo.id) : '/admin/usuarios';
%>

<main id="conteudo" class="container container--estreito">
  <h1 class="titulo-pagina"><%= editando ? 'Editar usuário' : 'Novo usuário' %></h1>

  <% if (erro) { %>
    <div class="alerta alerta--erro" role="alert"><%= erro %></div>
  <% } %>

  <form action="<%= action %>" method="post" class="painel formulario" novalidate>
    <div class="campo">
      <label for="nome">Nome *</label>
      <input type="text" id="nome" name="nome" required value="<%= editando ? alvo.nome : '' %>" />
    </div>
    <div class="campo">
      <label for="email">E-mail *</label>
      <input type="email" id="email" name="email" required value="<%= editando ? alvo.email : '' %>" />
    </div>
    <div class="campo">
      <label for="papel">Papel *</label>
      <select id="papel" name="papel" required>
        <% Object.values(enums.Papel).forEach(function (p) { %>
          <option value="<%= p %>" <%= editando && alvo.papel === p ? 'selected' : '' %>><%= p %></option>
        <% }); %>
      </select>
    </div>
    <div class="campo">
      <label for="senha">Senha <% if (editando) { %><span class="ajuda">(deixe em branco para manter)</span><% } else { %>* <span class="ajuda">(mín. 8 caracteres)</span><% } %></label>
      <input type="password" id="senha" name="senha" autocomplete="new-password" <%= editando ? '' : 'required minlength="8"' %> />
    </div>
    <% if (editando) { %>
      <label class="checkbox">
        <input type="checkbox" name="ativo" <%= alvo.ativo ? 'checked' : '' %> /> Conta ativa
      </label>
    <% } %>

    <div class="acoes-form">
      <button type="submit" class="btn btn--primario"><%= editando ? 'Salvar' : 'Criar usuário' %></button>
      <a href="/admin/usuarios" class="btn btn--ghost">Cancelar</a>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>
