@startuml diagrama-atividades
title Dicionário Libras+ — Atividades: Fluxo de aprovação de novo sinal
skinparam shadowing false

|Colaborador|
start
:Preencher dados do sinal\n(parâmetros gramaticais);
:Anexar vídeo (+ legenda);
if (Vídeo contém pessoa identificável?) then (sim)
  if (Consentimento registrado?) then (não)
    :Exibir erro de consentimento (LGPD);
    stop
  else (sim)
  endif
else (não)
endif
:Submeter;
|Sistema|
:Validar dados;
:Criar Sinal com status = PENDENTE;
:Registrar AuditLog (SUBMETER);

|Revisor|
:Abrir fila de aprovação;
:Selecionar submissão pendente;
:Analisar vídeo e parâmetros;
if (Decisão?) then (Aprovar)
  |Sistema|
  :Transição PENDENTE -> APROVADO -> PUBLICADO;
  :Registrar Revisao (APROVADO);
  :Registrar AuditLog (APROVAR);
  :Sinal disponível ao Visitante;
  |Visitante|
  :Pesquisar e visualizar sinal publicado;
  stop
else (Rejeitar)
  |Sistema|
  if (Justificativa informada?) then (não)
    :Recusar (justificativa obrigatória);
    stop
  else (sim)
  endif
  :Transição PENDENTE -> REJEITADO;
  :Registrar Revisao (REJEITADO);
  :Notificar autor (status em "Minhas submissões");
  |Colaborador|
  :Revisar/corrigir e reenviar;
  stop
endif
@enduml
