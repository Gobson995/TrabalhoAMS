# ============================================================================
# Dicionário Libras+ — Exemplo de variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# NUNCA commite o arquivo `.env` real (ele está no .gitignore).
# ============================================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000
# Segredo usado para assinar os cookies de sessão. Gere um valor aleatório forte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=troque-este-segredo-por-um-valor-aleatorio-forte

# --- Banco de dados PostgreSQL ---
# Estes valores devem bater com os do docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dicionario_libras
DB_USER=libras
DB_PASSWORD=libras_dev_password
# Alternativamente, uma URL única (tem precedência se preenchida):
# DATABASE_URL=postgres://libras:libras_dev_password@localhost:5432/dicionario_libras

# --- pgAdmin 4 (somente para o docker-compose) ---
# Use um e-mail com TLD válido; o pgAdmin 4 rejeita domínios como ".local".
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# --- Upload de mídia ---
# Tamanho máximo de vídeo em megabytes (RNF: até 50 MB)
MAX_VIDEO_SIZE_MB=50
MAX_IMAGE_SIZE_MB=5
UPLOAD_DIR=uploads

# --- Segurança ---
# Limite de tentativas de login por janela (RNF de segurança: 5/min)
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MS=60000
